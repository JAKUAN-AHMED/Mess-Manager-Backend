## Required ────────────────────────────────────────────
MONGODB_URI=
JWT_SECRET=change-me
PORT=5000
NODE_ENV=development

## Email — used to deliver monthly bills to members ────
## When SMTP_HOST is empty the email feature is silently disabled.
## Gmail: use an App Password (16 chars); spaces in the password are OK — they are stripped automatically.
SMTP_HOST=
SMTP_PORT=587
## Login: either pair works
SMTP_USER=
SMTP_PASS=
# or:
# SMTP_USERNAME=
# SMTP_PASSWORD=
## From address: either works (optional — defaults to "Mess Manager" <SMTP_USER>)
MAIL_FROM=
EMAIL_FROM=

## Cron — the secret Vercel Cron sends in `Authorization: Bearer <…>`
## On Vercel, set it under Project Settings → Environment Variables → CRON_SECRET.
## The `/api/reports/cron/send-monthly-bills` endpoint rejects requests without it.
CRON_SECRET=
